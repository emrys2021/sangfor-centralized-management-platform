# 复制为 .env 并按需修改。所有变量统一使用 SANGFOR_ 前缀，避免读到系统里的通用同名变量。

# 凭据加密主密钥（Fernet）。生产环境必须设置一个固定值，否则换机后无法解密已存凭据。
# 生成方式： python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SANGFOR_SECRET_KEY=

# API 访问令牌。设置后所有 /api 接口要求请求头 X-API-Token（或 Authorization: Bearer）匹配此值；
# 留空表示不鉴权（仅限受信任的内网开发环境，后端启动时会打印告警）。
# 前端需在 frontend/.env 设置 VITE_API_TOKEN 为相同值。
SANGFOR_API_TOKEN=

# 调试模式（默认 false）
# SANGFOR_DEBUG=false

# 数据库（默认 SQLite，位于 backend/data/sangfor.db）
# SANGFOR_DATABASE_URL=sqlite:///./data/sangfor.db

# 允许的前端来源（逗号分隔）
SANGFOR_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Sangfor 接口超时（秒）
SANGFOR_REQUEST_TIMEOUT=30

# 与 AC 通信的 TLS 校验：留空 / false 表示不校验（默认，适配自签证书设备）；
# true 表示用系统 CA 校验；其它值视为自定义 CA 证书文件路径。
# SANGFOR_VERIFY_TLS=false
